# Google Sheets
SHEET_ID=your_google_sheet_id_here
# Optional — Splash & Anno tools (ID - Settings tab). Omit to disable /api/splash and Tool C/D.
SPLASH_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/service-account.json

# CDN
CDN_BASE_URL=https://dl.dir.freefiremobile.com/common/

# Neon PostgreSQL (optional — checklist persists when set)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Admin auth (required in production; omit locally to disable login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=generate-a-random-string-at-least-32-characters-long

# Server
PORT=3001
NODE_ENV=development
CACHE_TTL_MS=300000
SPLASH_CACHE_TTL_MS=300000
# Splash fetch window — columns B:Z, bottom rows + date filter (mirrors banner “4 recent weeks”)
SPLASH_RECENT_WEEKS=4
SPLASH_RECENT_ROW_WINDOW=250
CDN_CHECK_CACHE_TTL_MS=600000
